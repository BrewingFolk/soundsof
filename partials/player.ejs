<div id="sticky-player">
  <img id="player-thumb" src="" alt="" class="player-thumb" style="display:none">
  <div class="player-info">
    <div class="player-title" id="player-title">Nothing playing</div>
    <div class="player-contributor" id="player-contributor"></div>
  </div>
  <div class="player-controls">
    <button class="player-play-btn" id="player-play-btn" aria-label="Play/Pause">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>
    </button>
    <div class="player-progress" id="player-progress">
      <div class="player-progress-fill" id="player-progress-fill" style="width:0%"></div>
    </div>
    <span class="player-time" id="player-time">0:00</span>
  </div>
  <div class="player-volume">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="opacity:0.5"><path d="M11 5L6 9H2v6h4l5 4V5zm4.07 1.93A8 8 0 0 1 18 12a8 8 0 0 1-2.93 6.07M14 9a4 4 0 0 1 0 6"/></svg>
    <input type="range" id="player-volume" min="0" max="1" step="0.05" value="0.8">
  </div>
  <button class="player-close" id="player-close" aria-label="Close">&times;</button>
  <audio id="player-audio" preload="metadata"></audio>
</div>
