<%- include('partials/head', {title: null}) %>
<body>
<%- include('partials/header') %>

<main>

  <%
    // Format date as MM/DD/YYYY (US style like reference)
    function fmtDate(d) {
      const dt = new Date(d);
      if (isNaN(dt)) return '';
      const m = String(dt.getMonth()+1).padStart(2,'0');
      const day = String(dt.getDate()).padStart(2,'0');
      const y = dt.getFullYear();
      return m+'/'+day+'/'+y;
    }
  %>

  <!-- HERO — featured (latest) post -->
  <% if (featured && featured.length > 0) { %>
  <%   const hero = featured[0]; %>
  <%   const heroContrib = contributors.find(c => c.id === hero.contributorId); %>
  <a href="/post/<%= hero.slug %>" class="hero" aria-label="<%= hero.title %>">
    <% if (hero.image) { %>
      <img src="<%= hero.image %>" alt="<%= hero.title %>" class="hero-img">
    <% } else { %>
      <div class="hero-placeholder">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
      </div>
    <% } %>
    <% if (hero.description || heroContrib) { %>
    <div class="hero-assoc">
      <% if (heroContrib) { %><span><%= heroContrib.name %></span><% } %>
    </div>
    <% } %>
    <span class="hero-title"><%= hero.title %></span>
  </a>
  <% } %>

  <!-- SITE DESCRIPTION -->
  <% if (settings.siteDescription) { %>
  <div class="site-description">
    <p>Sounds of... <%= settings.siteDescription %></p>
  </div>
  <% } %>

  <!-- POST LIST -->
  <div class="post-list">
    <% if (listed.length === 0) { %>
      <p style="padding:32px 0;color:#999;font-size:0.9rem;">No shows published yet. <a href="/admin/posts/new">Add your first show →</a></p>
    <% } else { %>
      <% listed.forEach(function(post) { %>
      <% const contrib = contributors.find(c => c.id === post.contributorId); %>
      <div class="post-list-item" onclick="location.href='/post/<%= post.slug %>'">

        <div class="post-list-left">
          <a href="/post/<%= post.slug %>" class="post-list-title"><%= post.title %></a>
          <div class="post-list-contributor">
            Sounds of
            <% if (contrib) { %>
              <a href="/contributor/<%= contrib.slug %>"><%= contrib.name %></a>
            <% } else { %>
              Brewing Folk
            <% } %>
          </div>
        </div>

        <div class="post-list-right">
          <span class="post-list-date"><%= fmtDate(post.publishedDate) %></span>
          <div class="post-list-cats">
            <% if (post.category) { %>
              <a href="/category/<%= slugify(post.category) %>" onclick="event.stopPropagation()"><%= post.category %></a>
            <% } %>
            <% if (post.showLength) { %>
              <% if (post.category) { %>&nbsp;/&nbsp;<% } %>
              <%= post.showLength %>
            <% } %>
          </div>
        </div>

      </div>
      <% }) %>
    <% } %>
  </div>

  <!-- PAGINATION -->
  <div class="pagination">
    <% if (hasOlder) { %><a href="/?page=<%= page + 1 %>">&larr; older</a><% } %>
    <% if (hasNewer) { %><a href="/?page=<%= page - 1 %>">newer &rarr;</a><% } %>
  </div>

</main>

<%- include('partials/footer') %>
<%- include('partials/player') %>
<script src="/js/main.js"></script>
</body>
</html>
