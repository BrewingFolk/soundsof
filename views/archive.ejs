<%- include('partials/head', {title: heading}) %>
<body>
<%- include('partials/header') %>

<%
  function fmtDate(d) {
    const dt = new Date(d);
    if (isNaN(dt)) return '';
    const m = String(dt.getMonth()+1).padStart(2,'0');
    const day = String(dt.getDate()).padStart(2,'0');
    const y = dt.getFullYear();
    return m+'/'+day+'/'+y;
  }
%>

<main>

  <h1 class="archive-heading"><%= heading %></h1>

  <div class="post-list">
    <% if (posts.length === 0) { %>
      <p style="padding:32px 0;color:#999;font-size:0.9rem;">No shows in this category yet.</p>
    <% } else { %>
      <% posts.forEach(function(post) { %>
      <% const contrib = contributors.find(c => c.id === post.contributorId); %>
      <div class="post-list-item" onclick="location.href='/post/<%= post.slug %>'">
        <div class="post-list-left">
          <a href="/post/<%= post.slug %>" class="post-list-title"><%= post.title %></a>
          <div class="post-list-contributor">
            Sounds of
            <% if (contrib) { %>
              <a href="/contributor/<%= contrib.slug %>" onclick="event.stopPropagation()"><%= contrib.name %></a>
            <% } else { %>
              Brewing Folk
            <% } %>
          </div>
        </div>
        <div class="post-list-right">
          <span class="post-list-date"><%= fmtDate(post.publishedDate) %></span>
          <div class="post-list-cats">
            <% if (post.category) { %>
              <a href="/category/<%= slugify(post.category) %>" onclick="event.stopPropagation()"><%= post.category %></a>
            <% } %>
            <% if (post.showLength) { %>
              <% if (post.category) { %>&nbsp;/&nbsp;<% } %><%= post.showLength %>
            <% } %>
          </div>
        </div>
      </div>
      <% }) %>
    <% } %>
  </div>

  <div class="pagination">
    <!-- pagination could go here if needed -->
  </div>

</main>

<%- include('partials/footer') %>
<%- include('partials/player') %>
<script src="/js/main.js"></script>
</body>
</html>
