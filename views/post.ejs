<%- include('partials/head', {title: post.title}) %>
<body>
<%- include('partials/header') %>

<%
  function fmtDate(d) {
    const dt = new Date(d);
    if (isNaN(dt)) return '';
    const m = String(dt.getMonth()+1).padStart(2,'0');
    const day = String(dt.getDate()).padStart(2,'0');
    const y = dt.getFullYear();
    return m+'/'+day+'/'+y;
  }
%>

<main>

  <!-- POST HEADER ROW: title left, category/duration right -->
  <div class="post-page-header">
    <h1 class="post-page-title"><%= post.title %></h1>
    <div class="post-page-meta">
      <% if (post.category) { %>
        <a href="/category/<%= slugify(post.category) %>"><%= post.category %></a>
      <% } %>
      <% if (post.showLength) { %>
        <% if (post.category) { %><span class="sep">/</span><% } %>
        <%= post.showLength %>
      <% } %>
    </div>
  </div>

  <!-- HERO IMAGE -->
  <% if (post.image) { %>
    <img src="<%= post.image %>" alt="<%= post.title %>" class="post-hero" style="margin-top:20px;">
  <% } else { %>
    <div class="post-hero-placeholder" style="margin-top:20px;">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
    </div>
  <% } %>

  <!-- INLINE AUDIO PLAYER -->
  <% if (post.audioUrl) { %>
  <div class="inline-player" id="inline-player" data-url="<%= post.audioUrl %>">
    <button class="inline-play-btn" id="inline-play-btn" aria-label="Play">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>
    </button>
    <span class="inline-time" id="inline-time">0:00</span>
    <div class="inline-progress-wrap" id="inline-progress-wrap">
      <div class="inline-progress-fill" id="inline-progress-fill"></div>
    </div>
  </div>
  <% } %>

  <!-- DESCRIPTION -->
  <% if (post.description) { %>
  <div class="post-desc-section"><%= post.description %></div>
  <% } %>

  <!-- PLAYLIST -->
  <% if (post.playlist && post.playlist.trim()) { %>
  <%   const tracks = post.playlist.split('\n').map(t => t.trim()).filter(Boolean); %>
  <div class="post-playlist-section">
    <div class="playlist-col-header">
      <span>Artist</span>
      <span>Track</span>
    </div>
    <% tracks.forEach(function(track) { %>
    <div class="playlist-row"><%= track %></div>
    <% }) %>
  </div>
  <% } %>

  <!-- DATE -->
  <div class="post-date-section">
    <span class="post-date-label">Date:</span>
    <span><%= fmtDate(post.publishedDate) %></span>
  </div>

  <!-- RELATED POSTS -->
  <% if (related && related.length > 0) { %>
  <div class="related-label">Other shows by <%= contributor ? contributor.name : 'Brewing Folk' %></div>
  <div class="post-list" style="margin-top:0;">
    <% related.forEach(function(rPost) { %>
    <% const rContrib = contributors ? contributors.find(c => c.id === rPost.contributorId) : contributor; %>
    <div class="post-list-item" onclick="location.href='/post/<%= rPost.slug %>'">
      <div class="post-list-left">
        <a href="/post/<%= rPost.slug %>" class="post-list-title"><%= rPost.title %></a>
        <div class="post-list-contributor">
          Sounds of
          <% if (rContrib) { %>
            <a href="/contributor/<%= rContrib.slug %>" onclick="event.stopPropagation()"><%= rContrib.name %></a>
          <% } else { %>
            Brewing Folk
          <% } %>
        </div>
      </div>
      <div class="post-list-right">
        <span class="post-list-date"><%= fmtDate(rPost.publishedDate) %></span>
        <div class="post-list-cats">
          <% if (rPost.category) { %>
            <a href="/category/<%= slugify(rPost.category) %>" onclick="event.stopPropagation()"><%= rPost.category %></a>
          <% } %>
          <% if (rPost.showLength) { %>
            <% if (rPost.category) { %>&nbsp;/&nbsp;<% } %><%= rPost.showLength %>
          <% } %>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>

</main>

<%- include('partials/footer') %>
<%- include('partials/player') %>
<script src="/js/main.js"></script>
</body>
</html>
