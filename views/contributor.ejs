<%- include('partials/head', {title: contributor.name}) %>
<body>
<%- include('partials/header') %>

<%
  function fmtDate(d) {
    const dt = new Date(d);
    if (isNaN(dt)) return '';
    const m = String(dt.getMonth()+1).padStart(2,'0');
    const day = String(dt.getDate()).padStart(2,'0');
    const y = dt.getFullYear();
    return m+'/'+day+'/'+y;
  }
%>

<main>

  <!-- LARGE NAME -->
  <h1 class="contributor-page-name"><%= contributor.name %></h1>

  <!-- SMALL CIRCLE IMAGE + BIO -->
  <div class="contributor-page-info">
    <% if (contributor.image) { %>
      <img src="<%= contributor.image %>" alt="<%= contributor.name %>" class="contributor-page-avatar">
    <% } else { %>
      <div class="contributor-page-avatar-placeholder">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
      </div>
    <% } %>
    <% if (contributor.bio) { %>
      <p class="contributor-page-bio"><%= contributor.bio %></p>
    <% } %>
  </div>

  <!-- SHOWS LABEL -->
  <div class="contributor-shows-label">Shows by <%= contributor.name %></div>

  <!-- POST LIST -->
  <div class="post-list" style="margin-top:0;">
    <% if (posts.length === 0) { %>
      <p style="padding:32px 0;color:#999;font-size:0.9rem;">No shows yet.</p>
    <% } else { %>
      <% posts.forEach(function(post) { %>
      <div class="post-list-item" onclick="location.href='/post/<%= post.slug %>'">
        <div class="post-list-left">
          <a href="/post/<%= post.slug %>" class="post-list-title"><%= post.title %></a>
          <div class="post-list-contributor">Sounds of <a href="/contributor/<%= contributor.slug %>" onclick="event.stopPropagation()"><%= contributor.name %></a></div>
        </div>
        <div class="post-list-right">
          <span class="post-list-date"><%= fmtDate(post.publishedDate) %></span>
          <div class="post-list-cats">
            <% if (post.category) { %>
              <a href="/category/<%= slugify(post.category) %>" onclick="event.stopPropagation()"><%= post.category %></a>
            <% } %>
            <% if (post.showLength) { %>
              <% if (post.category) { %>&nbsp;/&nbsp;<% } %><%= post.showLength %>
            <% } %>
          </div>
        </div>
      </div>
      <% }) %>
    <% } %>
  </div>

</main>

<%- include('partials/footer') %>
<%- include('partials/player') %>
<script src="/js/main.js"></script>
</body>
</html>
