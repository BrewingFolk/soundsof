<%- include('../partials/head', {title: 'Admin Login'}) %>
<body class="admin-body" style="display:flex;align-items:center;justify-content:center;min-height:100vh;padding:20px;">

<div style="width:100%;max-width:360px;">

  <div style="margin-bottom:32px;">
    <span style="font-size:0.75rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#999;">Sounds Of</span>
    <h1 style="font-size:1.75rem;font-weight:800;letter-spacing:-0.03em;margin-top:6px;">Admin</h1>
  </div>

  <% if (error) { %>
    <div style="background:#fee;border:1px solid #fcc;color:#c00;padding:10px 14px;font-size:0.8rem;margin-bottom:20px;"><%= error %></div>
  <% } %>

  <form method="POST" action="/admin/login">
    <div class="form-group">
      <label for="password">Password</label>
      <input type="password" id="password" name="password" autofocus autocomplete="current-password" placeholder="Enter admin password">
    </div>
    <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:12px;">Sign in</button>
  </form>

</div>

</body>
</html>
