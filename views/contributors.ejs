<%- include('partials/head', {title: 'Contributors'}) %>
<body>
<%- include('partials/header') %>
<main class="page-wrap">
  <div class="page-heading"><h1>Contributors</h1></div>
  <div class="contributors-grid">
    <% contributors.forEach(c => { %>
    <a href="/contributor/<%= c.slug %>" class="contributor-card-full" style="text-decoration:none;color:inherit;">
      <% if (c.image) { %>
        <img src="<%= c.image %>" alt="<%= c.name %>" class="contributor-card-img">
      <% } else { %>
        <div class="contributor-card-img-placeholder" style="display:flex;align-items:center;justify-content:center;">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
        </div>
      <% } %>
      <div class="contributor-card-name"><%= c.name %></div>
      <% if (c.bio) { %><p class="contributor-card-bio"><%= c.bio %></p><% } %>
    </a>
    <% }) %>
  </div>
</main>
<%- include('partials/footer') %>
<%- include('partials/player') %>
<script src="/js/main.js"></script>
</body>
</html>
